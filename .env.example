# ============================================================
# Sheaf — LLM API Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# --- Provider 1: SiliconFlow (China domestic models) ---
SILICONFLOW_API_KEY=your-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# --- Provider 2: OpenAI-compatible endpoint ---
# Any provider that follows the OpenAI API format works:
# OpenAI, Together, Fireworks, XTY, etc.
OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Default model selection ---
DEFAULT_PROVIDER=siliconflow
DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.2
