# ============================================================
# Sheaf — LLM API Configuration
# Copy this file to .env and fill in your keys
# ============================================================

# --- Primary: Any OpenAI-compatible endpoint ---
# Works with: OpenAI, DeepSeek, Together, Groq, SiliconFlow, etc.
# Or run: sheaf config setup  (interactive wizard, stores to ~/.sheaf/)

# OpenAI
# OPENAI_API_KEY=your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
# DEEPSEEK_API_KEY=your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# SiliconFlow
# SILICONFLOW_API_KEY=your-key-here
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Together AI
# TOGETHER_API_KEY=your-key-here
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Groq
# GROQ_API_KEY=your-key-here
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Default provider selection ---
# DEFAULT_PROVIDER=openai
# DEFAULT_MODEL=gpt-4o

# --- Optional: Semantic search / knowledge-card embeddings ---
# Issue #67 default closure path: SiliconFlow + BAAI/bge-m3.
# Uses an OpenAI-compatible embedding endpoint and keeps keyword search
# available when embeddings are not configured.
# EMBEDDING_API_KEY_ENV=SILICONFLOW_API_KEY
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024

# --- Optional: Override models for classification/summarization/crystallization ---
# CLASSIFY_MODEL=gpt-4o-mini
# SUMMARIZE_MODEL=gpt-4o
# CRYSTALLIZE_MODEL=gpt-4o
